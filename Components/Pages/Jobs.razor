@using MudBlazor
@using BlazorTaskScheduler.Quartz

@page "/jobs"
@inject IQuartzService QuartzService

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">Scheduled Jobs</MudText>

    @if (jobs == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudTable T="JobInfoData" Items="@jobs" Hover="true" Dense="true" Bordered="true" Striped="true">

            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Group</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Next Run</MudTh>
                <MudTh>Last Run</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>

            <!-- IMPORTANT: Context="job" MUST be here -->
            <RowTemplate Context="job">
                <MudTd>@job.Name</MudTd>
                <MudTd>@job.Group</MudTd>
                <MudTd>@job.Description</MudTd>
                <MudTd>@Format(job.NextRun)</MudTd>
                <MudTd>@Format(job.LastRun)</MudTd>

                <MudTd>
                    <MudChip T="string" Color="@(job.IsPaused ? Color.Warning : Color.Success)">
                        @(job.IsPaused ? "Paused" : "Active")
                    </MudChip>
                </MudTd>

                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudButton Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => RunNow(job))">
                            Run
                        </MudButton>

                        @if (job.IsPaused)
                        {
                            <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined"
                                       OnClick="@(() => Resume(job))">
                                Resume
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                       OnClick="@(() => Pause(job))">
                                Pause
                            </MudButton>
                        }
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    List<JobInfoData> jobs;

    protected override async Task OnInitializedAsync()
    {
        jobs = await QuartzService.GetJobsAsync();
    }

    string Format(DateTimeOffset? dto)
        => dto?.ToLocalTime().ToString("g") ?? "-";

    async Task RunNow(JobInfoData job)
    {
        await QuartzService.RunJobNow(job.Name, job.Group);
        jobs = await QuartzService.GetJobsAsync();
    }

    async Task Pause(JobInfoData job)
    {
        await QuartzService.PauseJob(job.Name, job.Group);
        jobs = await QuartzService.GetJobsAsync();
    }

    async Task Resume(JobInfoData job)
    {
        await QuartzService.ResumeJob(job.Name, job.Group);
        jobs = await QuartzService.GetJobsAsync();
    }
}
